# ═══════════════════════════════════════════════════════════════
#  InfraGuard AI v2 – Environment Variables Template
#  Copy to .env and fill in your API keys
# ═══════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false
RATE_LIMIT_PER_MIN=120
ENVIRONMENT=production

# ── Database (Railway provides these automatically) ─────────────
DATABASE_URL=postgresql+asyncpg://infraguard:CHANGE_ME@localhost:5432/infraguard
REDIS_URL=redis://localhost:6379
POSTGRES_PASSWORD=CHANGE_ME

# ── Cache TTLs (seconds) ────────────────────────────────────────
REDIS_TTL_TRAFFIC=300
REDIS_TTL_AQI=600
REDIS_TTL_WEATHER=900
REDIS_TTL_FLOOD=3600
REDIS_TTL_PREDICTION=1800
REDIS_TTL_SCRAPE=86400

# ── Auth ────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── CORS ────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["https://infraguardai.tech","https://www.infraguardai.tech","http://localhost:3000"]

# ── API Keys ────────────────────────────────────────────────────
TOMTOM_API_KEY=YOUR_TOMTOM_KEY
OPENWEATHER_API_KEY=YOUR_OPENWEATHER_KEY
WAQI_API_KEY=YOUR_WAQI_KEY
NOAA_API_KEY=YOUR_NOAA_KEY
HERE_API_KEY=YOUR_HERE_KEY

# ── Logging ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/infraguard.log
